FROM golang:1.23-alpine AS builder
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -trimpath -ldflags="-s -w" -o /ingester ./cmd/ingester

FROM alpine:3.20
RUN apk add --no-cache ca-certificates tzdata
COPY --from=builder /ingester /ingester
ENTRYPOINT ["/ingester"]
